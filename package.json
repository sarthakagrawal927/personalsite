{
  "name": "sarthak-blog",
  "version": "2.0.2",
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev",
    "build": "cross-env INIT_CWD=$PWD next build --webpack && node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint .",
    "cf:build": "opennextjs-cloudflare build",
    "deploy": "pnpm cf:build && rm -rf .pages-deploy && mkdir -p .pages-deploy && cp -r .open-next/assets/. .pages-deploy/ && cp -r .open-next/cloudflare .pages-deploy/ && cp -r .open-next/middleware .pages-deploy/ && cp -r .open-next/.build .pages-deploy/ && cp -r .open-next/server-functions .pages-deploy/ && cp .open-next/worker.js .pages-deploy/_worker.js && node -e 'require(\"fs\").writeFileSync(\".pages-deploy/_routes.json\", JSON.stringify({version:1,include:[\"/*\"],exclude:[\"/_next/static/*\",\"/cdn-cgi/_next_cache/*\",\"/favicon.ico\",\"/static/*\",\"/feed.xml\"]}))' && wrangler pages deploy --project-name=personalsite --branch=main"
  },
  "dependencies": {
    "@next/bundle-analyzer": "16.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "contentlayer2": "^0.5.8",
    "esbuild": "0.28.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "2.0.2",
    "next": "16.2.4",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "pliny": "0.4.1",
    "postcss": "^8.5.12",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.2.4",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@saas-maker/eslint-config": "^1.0.5",
    "@saas-maker/prettier-config": "^1.0.0",
    "@saas-maker/tsconfig": "^1.0.0",
    "@svgr/webpack": "^8.1.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  },
  "resolutions": {
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/core": "1.13.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.39.1",
    "@opentelemetry/resources": "1.13.0",
    "@opentelemetry/sdk-trace-base": "1.13.0",
    "@opentelemetry/sdk-trace-node": "1.13.0",
    "@opentelemetry/semantic-conventions": "1.13.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "prettier": "@saas-maker/prettier-config"
}